generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Family {
  id        String         @id @default(cuid())
  name      String
  createdAt DateTime       @default(now())
  children  Child[]
  event    Event[]
  members   FamilyMember[]
  users User[]
}

model FamilyMember {
  id          String   @id @default(cuid())
  displayName String
  role        String
  familyId     String
  createdAt   DateTime @default(now())
  family      Family   @relation(fields: [familyId], references: [id])
}

model Child {
  id         String   @id @default(cuid())
  name     String
  birthdate  DateTime
  schoolName String?
  doctorName String?
  familyId   String
  createdAt  DateTime @default(now())
  family     Family   @relation(fields: [familyId], references: [id])
  event      Event[]
}

model Event {
  id         String   @id @default(cuid())
  title      String
  type       String
  startAt    DateTime
  location   String?
  assignedTo String?
  childId    String?
  familyId   String
  createdAt  DateTime @default(now())
  child      Child?   @relation(fields: [childId], references: [id])
  family     Family   @relation(fields: [familyId], references: [id])
}

model User{
   id        String   @id @default(cuid())
  email     String   @unique
  password  String
  familyId  String
  family    Family   @relation(fields: [familyId], references: [id])
  createdAt DateTime @default(now())
}